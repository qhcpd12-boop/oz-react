# 복사: cp .env.example .env 후 값 채우기
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# llama-server OpenAI 호환 경로는 보통 /v1 (요청하신 값이 /n1이면 그대로 두세요)
VITE_LLAMACAPP_BASE_URL=http://localhost:8080/n1

VITE_MODEL=llamacpp/local-model
VITE_MODEL_OPUS=llamacpp/local-model

VITE_MODEL_SONNET=llamacpp/local-madel

VITE_MODEL_HATKU=llamacpp/local-model
